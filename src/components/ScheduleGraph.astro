---
import ScheduleGrid from "./ScheduleGrid.astro";
import { type ScheduleEntry } from "../lib/WebMaster/schedule";

export interface Props {
	groupBy: "platform" | "channel";
	groupedSchedule: Record<string, Array<ScheduleEntry>>;
	dayOrder: Array<string>;
}

const { groupBy, groupedSchedule, dayOrder }: Props = Astro.props;
---
<div class="schedule-container">
	{dayOrder.map((dayName: string) =>
		groupedSchedule[dayName] && (
			<section class="day-group">
				<h3 class="p-name">{dayName}</h3>
				<ScheduleGrid events={groupedSchedule[dayName]} groupBy={groupBy} />
			</section>
		)
	)}
</div>