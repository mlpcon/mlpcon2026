---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getVendors, type Vendor } from "../lib/vendors";
import type { ImageMetadata } from "astro";

// 1. Grab all images in the folder
const imageImports: Record<string, () => Promise<{ default: ImageMetadata }>> = import.meta.glob<{ default: ImageMetadata }>(
	"/src/assets/images/vendors/*.{jpeg,jpg,png,gif,webp}",
);
const allImagePaths: Array<string> = Object.keys(imageImports);

const vendors: Array<Vendor> = await getVendors();

// 2. Helper to turn "Rocket's Equine Outpost" into "rockets-equine-outpost"
function slugify(text: string): string {
	return text
		.toString()
		.toLowerCase()
		.replace(/\s+/g, "-")
		.replace(/[^\w\-]+/g, "")
		.replace(/\-\-+/g, "-")
		.replace(/^-+/, "")
		.replace(/-+$/, "");
}

// 3. Pre-resolve all vendor images here in the frontmatter
const vendorDataWithImages: Array<Vendor & { images: Array<ImageMetadata> }> = await Promise.all(
	vendors.map(async (vendor: Vendor) => {
		const slug: string = slugify(vendor.name);
		const matchedPaths: Array<string> = allImagePaths.filter((path: string) => {
			const filename: string = path.split("/").pop() || "";
			return filename.startsWith(`${slug}-`);
		});

		matchedPaths.sort();

		// Await the imports here so the template gets ready-to-use metadata
		const resolvedImages: Array<ImageMetadata> = await Promise.all(
			matchedPaths.map(async (path: string) => {
				const mod: { default: ImageMetadata } = await imageImports[path]();
				return mod.default;
			}),
		);

		return { ...vendor, images: resolvedImages };
	}),
);

// Pre-resolve the placeholder image
const placeholderPath: string | undefined = allImagePaths.find((path: string) => path.split("/").pop()?.startsWith("default."));
const placeholderMetadata: ImageMetadata | null = placeholderPath ? (await imageImports[placeholderPath]()).default : null;
---

<Layout title="Vendor Hall">
	<h2>Vendor Hall</h2>

	<div class="vendor-grid">
		{
			vendorDataWithImages.map((vendor) => (
				<article class="vendor-card" itemscope itemtype="https://schema.org/Organization">
					<header>
						<h3 itemprop="name">{vendor.name}</h3>
					</header>

					<div class="vendor-images" itemprop="makesOffer" itemscope itemtype="https://schema.org/Offer">
						{vendor.images.length > 0
							? vendor.images.map((imgMetadata: ImageMetadata) => (
									<Image
										src={imgMetadata}
										alt={`Artwork or product from ${vendor.name}`}
										width={200}
										class="vendor-img"
										itemprop="image"
										data-full={imgMetadata.src}
									/>
								))
							: placeholderMetadata && (
									<Image src={placeholderMetadata} alt="Image Missing" width={200} class="vendor-img placeholder" data-full={placeholderMetadata.src} />
								)}
					</div>
					<div>
						{vendor.url && (
							<a href={vendor.url} itemprop="url" target="_blank" rel="noopener noreferrer">
								Visit Website
							</a>
						)}
					</div>
					<div class="vendor-description" itemprop="description" set:html={vendor.descriptionHtml} />
				</article>
			))
		}
	</div>

	<dialog id="lightbox" class="lightbox">
		<button id="close-lightbox" aria-label="Close gallery" class="lightbox-close">&times;</button>
		<img id="lightbox-image" src="" alt="Full screen view" />
	</dialog>
</Layout>

<script>
	const lightbox: HTMLDialogElement = document.getElementById("lightbox") as HTMLDialogElement;
	const lightboxImg: HTMLImageElement = document.getElementById("lightbox-image") as HTMLImageElement;
	const closeBtn: HTMLButtonElement = document.getElementById("close-lightbox") as HTMLButtonElement;
	const allVendorImages: NodeListOf<HTMLImageElement> = document.querySelectorAll(".vendor-img") as NodeListOf<HTMLImageElement>;

	allVendorImages.forEach((img: HTMLImageElement) => {
		img.addEventListener("click", () => {
			const fullSizeUrl: string | null = img.getAttribute("data-full");

			if (fullSizeUrl) {
				lightboxImg.src = fullSizeUrl;
				lightbox.showModal();
			}
		});
	});

	closeBtn?.addEventListener("click", () => lightbox.close());
	lightbox.addEventListener("click", (e: PointerEvent) => {
		if (e.target === lightbox) lightbox.close();
	});
</script>

<style>
	.vendor-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 2rem;
		padding: 1rem;
	}
	.vendor-card {
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 12px;
		padding: 1.5rem;
		background: rgba(255, 255, 255, 0.02);
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.vendor-images {
		display: flex;
		overflow-x: auto;
		gap: 1rem;
		scroll-snap-type: x mandatory;
		padding-bottom: 1rem;
		justify-content: center;
	}
	.vendor-img {
		scroll-snap-align: start;
		flex-shrink: 0;
		width: 100%;
		max-width: 200px;
		aspect-ratio: 4 / 3;
		object-fit: contain;
		border-radius: 8px;
		background-color: rgba(0, 0, 0, 0.05);
		cursor: pointer;
		transition: transform 0.2s ease;
	}
	.vendor-img:hover {
		transform: scale(1.05);
	}
	.vendor-description {
		line-height: 1.6;
		font-size: 0.95rem;
	}
	.lightbox {
		max-width: 100vw;
		max-height: 100vh;
		width: 100%;
		height: 100%;
		margin: auto;
		padding: 0;
		border: none;
		background: transparent;
		overflow: hidden;
		display: none;
		align-items: center;
		justify-content: center;
	}
	.lightbox[open] {
		display: flex;
	}
	.lightbox::backdrop {
		background: rgba(0, 0, 0, 0.9);
		backdrop-filter: blur(8px);
	}
	.lightbox img {
		display: block;
		max-width: 95vw;
		max-height: 95vh;
		width: auto;
		height: auto;
		object-fit: contain;
		box-shadow: 0 0 50px rgba(0, 0, 0, 0.8);
		border-radius: 4px;
	}
	.lightbox-close {
		position: fixed;
		top: 20px;
		right: 30px;
		background: rgba(255, 255, 255, 0.1);
		border: 1px solid rgba(255, 255, 255, 0.3);
		border-radius: 50%;
		width: 50px;
		height: 50px;
		color: white;
		font-size: 30px;
		cursor: pointer;
		z-index: 100;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.2s;
	}
	.lightbox-close:hover {
		background: rgba(255, 255, 255, 0.2);
	}
</style>
