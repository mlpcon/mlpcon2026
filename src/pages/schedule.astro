---
import Layout from "../layouts/Layout.astro";
import { getSchedule, type ScheduleEntry } from "../lib/schedule";

interface CytubeMetadata {
	name: string;
	url: string;
}

const schedule: Array<ScheduleEntry> = await getSchedule();

// Grouping logic using your new "Day" column
const groupedSchedule: Record<string, Array<ScheduleEntry>> = schedule.reduce(
	(groups: Record<string, Array<ScheduleEntry>>, entry: ScheduleEntry) => {
		const day: string = entry.day || "TBD";

		if (!groups[day]) groups[day] = [];
		groups[day].push(entry);
		return groups;
	},
	{} as Record<string, Array<ScheduleEntry>>,
);

// We define the order explicitly since Object.keys can be unpredictable
const dayOrder: Array<string> = ["Friday", "Saturday", "Sunday"];

function getCytubeUrl(channel: string): CytubeMetadata {
	switch (channel) {
		case "1":
			return { name: "CyTube 1", url: "//cytu.be/r/mlp-con" };
		case "2":
			return { name: "CyTube 2", url: "//cytu.be/r/mlp-con2" };
		default:
			return { name: channel, url: `//cytu.be/r/${channel}` };
	}
}
---

<Layout title="Schedule" description="See the schedule for /mlp/ con 2026! Don't suffer from FOMO, be sure to catch your favorites.">
	<h2>Event Schedule</h2>
	<p>All times will automatically convert to your local timezone if you've enabled JavaScript.</p>
	<p>
		See the schedule in <a href="//docs.google.com/spreadsheets/d/1RYx3sVxTTk8YV-xpkJSsL1aqW0I3uF6yBACnnZGZExw/edit?gid=0#gid=0" target="_blank" rel="noopener noreferrer"
			>spreadsheet form here.</a
		>
	</p>

	<div class="schedule-container">
		{
			dayOrder.map(
				(dayName: string) =>
					groupedSchedule[dayName] && (
						<section class="day-group">
							<header class="day-header">
								<h3 class="p-name">{dayName}</h3>
							</header>

							{groupedSchedule[dayName].map((event: ScheduleEntry) => {
								const cytube: CytubeMetadata = getCytubeUrl(event.channel);

								return (
									<article class="h-event schedule-item" itemscope itemtype="https://schema.org/Event">
										<h4 class="p-name" itemprop="name">
											{event.title}
										</h4>
										<div class="meta">
											<time class="dt-start" datetime={event.startTime} itemprop="startDate">
												{event.startTime}
											</time>
											Duration:{" "}
											<time class="dt-duration" datetime={event.duration.toString()} itemprop="duration">
												{event.duration}
											</time>
										</div>
										<div class="meta">
											Streaming to{" "}
											<span class="location">
												<a href={cytube.url} itemprop="url" target="_blank" rel="external noopener">
													{cytube.name}
												</a>
											</span>
										</div>
										<p class="p-summary" itemprop="description">
											{event.description}
										</p>
									</article>
								);
							})}
						</section>
					),
			)
		}
	</div>

	<script>
		interface Duration {
			hours: number;
			minutes: number;
		}

		(function (): void {
			function localizeTimes(): void {
				const formatter: Intl.DateTimeFormat = new Intl.DateTimeFormat([], {
					day: "numeric",
					hour: "numeric",
					minute: "2-digit",
					month: "long",
					timeZoneName: "short",
					weekday: "long",
				});

				document.querySelectorAll(".dt-start").forEach((time: Element) => {
					const timeEl: HTMLTimeElement = time as HTMLTimeElement;

					if (timeEl.dateTime) {
						// Handles space-separated date strings correctly
						const parsedDate: Date = new Date(timeEl.dateTime.replace(" ", "T"));
						timeEl.textContent = formatter.format(parsedDate);
					}
				});
			}

			function formatDurations(): void {
				function getDuration(isoString: string): Partial<Record<Intl.DurationFormatUnit, number>> {
					const regex: RegExp = /PT(?:(\d+)H)?(?:(\d+)M)?/;
					const matches: RegExpMatchArray | null = isoString.match(regex);

					if (!matches) return { minutes: 0 };
					return {
						hours: parseInt(matches[1] || "0", 10),
						minutes: parseInt(matches[2] || "0", 10),
					};
				}

				const formatter: Intl.DurationFormat = new Intl.DurationFormat("en", { style: "long" });
				document.querySelectorAll(".dt-duration").forEach((duration: Element) => {
					const durationEl: HTMLTimeElement = duration as HTMLTimeElement;

					if (durationEl.dateTime) durationEl.textContent = formatter.format(getDuration(durationEl.dateTime));
				});
			}

			if (typeof Intl !== "undefined" && typeof Intl.DateTimeFormat !== "undefined") {
				if (typeof Intl.DateTimeFormat !== "undefined") localizeTimes();

				if (typeof Intl.DurationFormat !== "undefined") formatDurations();
			}
		})();
	</script>
</Layout>

<style>
	.day-header {
		background-color: var(--color-blurple);
		padding: 0.5rem 1.5rem;
		margin: 2.5rem 0 1.5rem 0;
		border-radius: 4px;
	}
	.day-header h2 {
		margin: 0;
		font-size: 1.8rem;
		color: var(--color-light);
	}
	.schedule-item {
		background: rgba(255, 255, 255, 0.05);
		border-left: 4px solid var(--color-grey);
		padding: 1.5rem;
		margin-bottom: 1rem;
		text-align: left;
	}
	.meta {
		font-size: 0.95rem;
		color: var(--color-grey);
		margin-bottom: 0.75rem;
		font-weight: bold;
	}
	.meta span,
	.meta time {
		margin-right: 20px;
	}
	.p-summary {
		line-height: 1.6;
		margin: 0;
	}
</style>
